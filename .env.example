# 复制为 .env 后填写（切勿提交真实 .env）
PORT=3000
NODE_ENV=production

# Prisma 使用 DATABASE_URL（PostgreSQL）
# 本机 npm 直连：postgresql://lims:PASSWORD@localhost:5432/lims?schema=public
# API 在 Docker、PostgreSQL 在宿主机（生产推荐，勿用 localhost）：
#   postgresql://lims:PASSWORD@host.docker.internal:5432/lims?schema=public
# 宿主机网络模式 API（compose hostnetwork）：postgresql://lims:PASSWORD@127.0.0.1:5432/lims?schema=public
# 云托管 PostgreSQL：postgresql://USER:PASSWORD@your-rds.xxx:5432/lims?schema=public
DATABASE_URL=postgresql://lims:PASSWORD@HOST:5432/lims?schema=public

JWT_SECRET=
JWT_REFRESH_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=


APP_ID=
APP_SECRET=

# 日志：trace|debug|info|warn|error|fatal|silent（勿填 production/development，会与 NODE_ENV 混淆）
LOG_LEVEL=info



