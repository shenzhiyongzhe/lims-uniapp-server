# 复制为 .env 后填写（切勿提交真实 .env）
PORT=3000
NODE_ENV=production

# Prisma 只读 DATABASE_URL（须含正确主机名，勿在容器内用 localhost 指宿主机或他机）
# 本机 npm 直连：mysql://USER:PASSWORD@localhost:3306/lims
# API 与 MySQL 同一 compose 且服务名为 mysql：mysql://USER:PASSWORD@mysql:3306/lims
# MySQL 在宿主机、API 用本仓库 docker-compose（已配 extra_hosts）：mysql://USER:PASSWORD@host.docker.internal:3306/lims
# 云数据库：mysql://USER:PASSWORD@your-rds.xxx.rds.aliyuncs.com:3306/lims
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/lims
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=lims
# 以下仅给应用里其它读取用；Prisma 以 DATABASE_URL 为准
DATABASE_HOST=localhost
DATABASE_PORT=3306

JWT_SECRET=
JWT_REFRESH_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

EMERGENCY_RESET_SECRET_KEY=

APP_ID=
APP_SECRET=

# 日志：trace|debug|info|warn|error|fatal|silent（勿填 production/development，会与 NODE_ENV 混淆）
LOG_LEVEL=info

# 小程序 / 前端访问 API 的根地址（HTTPS 域名）
NEXT_PUBLIC_API_BASE=https://www.xinde8888.com

# 生产环境拉取镜像（docker-compose.prod.yml）
# DOCKER_IMAGE=ghcr.io/<github-owner>/lims-uniapp-server:latest
