# 复制为 .env 后填写（切勿提交真实 .env）
PORT=3000
NODE_ENV=production

# Prisma / MySQL（Docker 内数据库主机名为 mysql 时使用 mysql-compose 叠加文件）
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/lims
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=lims
DATABASE_HOST=localhost
DATABASE_PORT=3306

JWT_SECRET=
JWT_REFRESH_SECRET=
CRON_SECRET=
ADMIN_PASSWORD=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

EMERGENCY_RESET_SECRET_KEY=

APP_ID=
APP_SECRET=

LOG_LEVEL=info

# 小程序 / 前端访问 API 的根地址（HTTPS 域名）
NEXT_PUBLIC_API_BASE=https://www.xinde8888.com

# 生产环境拉取镜像（docker-compose.prod.yml）
# DOCKER_IMAGE=ghcr.io/<github-owner>/lims-uniapp-server:latest
